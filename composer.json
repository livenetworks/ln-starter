{
    "name": "livenetworks/ln-starter",
    "description": "Laravel foundation package — base controllers, models, DTOs, and middleware for dual-mode (browser + API) applications.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Live Networks",
            "homepage": "https://livenetworks.mk"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/mail": "^11.0|^12.0",
        "laravel/sanctum": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "LiveNetworks\\LnStarter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LiveNetworks\\LnStarter\\LnStarterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
